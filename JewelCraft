<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Troy Clancy Jewellery • JewelCraft Insights v2.9</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
  </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">
  <div class="flex h-screen">
    <!-- SIDEBAR -->
    <div class="w-72 bg-zinc-900 border-r border-zinc-800 flex flex-col">
      <div class="p-6 border-b border-zinc-800">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gradient-to-br from-amber-400 to-yellow-600 rounded-xl flex items-center justify-center text-xl">💎</div>
          <div><h1 class="text-2xl font-bold tracking-tight">JewelCraft</h1><p class="text-amber-400 text-sm">Troy Clancy Jewellery • Burleigh Heads</p></div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-1" id="nav"></nav>
      <div class="p-4 border-t border-zinc-800 text-xs text-zinc-500">Local • Private • v2.9 + Content Logger</div>
    </div>

    <div class="flex-1 flex flex-col">
      <header class="h-16 bg-zinc-900 border-b border-zinc-800 px-8 flex items-center justify-between">
        <h2 id="page-title" class="text-2xl font-semibold">Best Performing Content Logger</h2>
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2 text-sm"><div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div><span class="text-emerald-400">Local Mode</span></div>
        </div>
      </header>
      <div class="flex-1 overflow-auto p-8" id="main-content"></div>
    </div>
  </div>

  <script>
    let contentLogs = JSON.parse(localStorage.getItem('troyContentLogs')) || [];

    function saveContentLogs() {
      localStorage.setItem('troyContentLogs', JSON.stringify(contentLogs));
    }

    function renderContentLogger() {
      const content = document.getElementById('main-content');
      content.innerHTML = `
        <div class="max-w-6xl mx-auto">
          <div class="flex justify-between mb-8">
            <h3 class="text-2xl font-semibold">Best Performing Content Logger</h3>
            <button onclick="addContentLog()" class="bg-amber-400 text-zinc-950 px-8 py-4 rounded-3xl font-semibold">+ Log New Content</button>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Performance Chart -->
            <div class="bg-zinc-900 rounded-3xl p-6">
              <h4 class="font-medium mb-4">Top Content Types by Engagement</h4>
              <canvas id="contentChart" class="h-80"></canvas>
            </div>

            <!-- Recent Logs -->
            <div class="bg-zinc-900 rounded-3xl p-6 overflow-auto max-h-[500px]">
              <h4 class="font-medium mb-4">Recent Logs</h4>
              <div id="recent-logs" class="space-y-4"></div>
            </div>
          </div>

          <div class="mt-8 bg-zinc-900 rounded-3xl p-6">
            <h4 class="font-medium mb-4">All Content Logs</h4>
            <table class="w-full text-sm" id="logs-table"></table>
          </div>
        </div>
      `;

      renderContentChart();
      renderLogs();
    }

    window.addContentLog = function() {
      const modal = document.createElement('div');
      modal.className = "fixed inset-0 bg-black/80 flex items-center justify-center z-50";
      modal.innerHTML = `
        <div class="bg-zinc-900 rounded-3xl p-8 w-full max-w-lg">
          <h3 class="text-xl font-semibold mb-6">Log Content Performance</h3>
          
          <div class="space-y-6">
            <div><label class="text-xs block mb-1">Date</label><input id="log-date" type="date" value="${new Date().toISOString().split('T')[0]}" class="w-full bg-zinc-800 rounded-2xl p-4"></div>
            
            <div><label class="text-xs block mb-1">Content Type</label>
              <select id="log-type" class="w-full bg-zinc-800 rounded-2xl p-4">
                <option>Workshop Reel (Craftsman's Table)</option>
                <option>Transformation Tuesday (Before/After)</option>
                <option>Education Carousel</option>
                <option>Client Story / Sketch to Sparkle</option>
                <option>Pinterest Pin</option>
                <option>TikTok Short</option>
                <option>Story / Poll</option>
                <option>Other</option>
              </select>
            </div>
            
            <div class="grid grid-cols-2 gap-6">
              <div><label class="text-xs block mb-1">Views / Impressions</label><input id="log-views" type="number" placeholder="e.g. 14500" class="w-full bg-zinc-800 rounded-2xl p-4"></div>
              <div><label class="text-xs block mb-1">Engagement (Likes + Comments + Saves)</label><input id="log-engagement" type="number" placeholder="e.g. 890" class="w-full bg-zinc-800 rounded-2xl p-4"></div>
            </div>
            
            <div><label class="text-xs block mb-1">Enquiries / Leads Generated</label><input id="log-leads" type="number" placeholder="e.g. 5" class="w-full bg-zinc-800 rounded-2xl p-4"></div>
            <div><label class="text-xs block mb-1">Notes (what worked?)</label><textarea id="log-notes" class="w-full bg-zinc-800 rounded-3xl p-4 h-20" placeholder="e.g. Used ASMR polishing sound + strong CTA"></textarea></div>
          </div>

          <div class="flex gap-4 mt-8">
            <button onclick="saveContentEntry()" class="flex-1 bg-amber-400 text-zinc-950 py-5 rounded-3xl font-semibold">Save Log</button>
            <button onclick="this.closest('.fixed').remove()" class="flex-1 bg-zinc-800 py-5 rounded-3xl">Cancel</button>
          </div>
        </div>`;
      document.body.appendChild(modal);
    };

    window.saveContentEntry = function() {
      const entry = {
        date: document.getElementById('log-date').value,
        type: document.getElementById('log-type').value,
        views: parseInt(document.getElementById('log-views').value) || 0,
        engagement: parseInt(document.getElementById('log-engagement').value) || 0,
        leads: parseInt(document.getElementById('log-leads').value) || 0,
        notes: document.getElementById('log-notes').value
      };
      contentLogs.unshift(entry);
      saveContentLogs();
      document.querySelector('.fixed').remove();
      renderContentLogger();
    };

    function renderContentChart() {
      const ctx = document.getElementById('contentChart');
      if (!ctx) return;

      // Simple aggregation by type
      const summary = {};
      contentLogs.forEach(log => {
        if (!summary[log.type]) summary[log.type] = { views: 0, leads: 0 };
        summary[log.type].views += log.views;
        summary[log.type].leads += log.leads;
      });

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: Object.keys(summary),
          datasets: [
            { label: 'Total Views', data: Object.values(summary).map(s => s.views), backgroundColor: '#d4af77' },
            { label: 'Leads Generated', data: Object.values(summary).map(s => s.leads), backgroundColor: '#10b981' }
          ]
        },
        options: { scales: { y: { beginAtZero: true } } }
      });
    }

    function renderLogs() {
      // Recent logs + full table (populated dynamically)
      let recentHTML = '';
      contentLogs.slice(0, 5).forEach(log => {
        recentHTML += `<div class="bg-zinc-800 rounded-2xl p-4"><div class="font-medium">${log.type}</div><div class="text-xs text-zinc-400">${log.date} • ${log.views} views • ${log.leads} leads</div><div class="text-xs mt-2">${log.notes}</div></div>`;
      });
      document.getElementById('recent-logs').innerHTML = recentHTML || '<p class="text-zinc-400">No logs yet. Add your first content performance entry.</p>';

      // Full table would go here (abbreviated for response length)
      document.getElementById('logs-table').innerHTML = `<thead><tr><th class="p-4 text-left">Date</th><th class="p-4 text-left">Type</th><th class="p-4 text-left">Views</th><th class="p-4 text-left">Leads</th></tr></thead><tbody>${contentLogs.map(log => `<tr><td class="p-4">${log.date}</td><td class="p-4">${log.type}</td><td class="p-4">${log.views}</td><td class="p-4 text-emerald-400">${log.leads}</td></tr>`).join('')}</tbody>`;
    }

    // Init
    renderContentLogger();
  </script>
</body>
</html>
