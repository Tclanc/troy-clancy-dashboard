<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Troy Clancy Jewellery • JewelCraft</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
  </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

  <!-- PASSWORD SCREEN -->
  <div id="password-screen" class="fixed inset-0 bg-zinc-950 flex items-center justify-center z-50">
    <div class="bg-zinc-900 rounded-3xl p-12 w-full max-w-md text-center">
      <div class="text-5xl mb-6">💎</div>
      <h1 class="text-3xl font-bold mb-2">JewelCraft Insights</h1>
      <p class="text-amber-400 mb-8">Troy Clancy Jewellery • Private</p>
      <input id="password-input" type="password" placeholder="Enter Password" class="w-full bg-zinc-800 text-center rounded-2xl p-5 text-lg mb-6">
      <button onclick="checkPassword()" class="w-full bg-amber-400 text-zinc-950 font-semibold py-5 rounded-3xl text-lg">UNLOCK DASHBOARD</button>
      <p id="error-msg" class="text-red-400 mt-4 text-sm hidden">Incorrect password</p>
    </div>
  </div>

  <!-- MAIN APP -->
  <div id="main-app" class="hidden flex h-screen">
    <div class="w-72 bg-zinc-900 border-r border-zinc-800 flex flex-col">
      <div class="p-6 border-b border-zinc-800">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gradient-to-br from-amber-400 to-yellow-600 rounded-xl flex items-center justify-center text-xl">💎</div>
          <div><h1 class="text-2xl font-bold">JewelCraft</h1><p class="text-amber-400 text-sm">Troy Clancy</p></div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-1" id="nav"></nav>
    </div>

    <div class="flex-1 flex flex-col">
      <header class="h-16 bg-zinc-900 border-b border-zinc-800 px-8 flex items-center justify-between">
        <h2 id="page-title" class="text-2xl font-semibold">Dashboard</h2>
      </header>
      <div class="flex-1 overflow-auto p-8" id="main-content"></div>
    </div>
  </div>

  <script>
    const CORRECT_PASSWORD = "c99#1@axWTE!NH^B";

    function checkPassword() {
      if (document.getElementById('password-input').value === CORRECT_PASSWORD) {
        document.getElementById('password-screen').classList.add('hidden');
        document.getElementById('main-app').classList.remove('hidden');
        buildNav();
        pages.dashboard.render();
      } else {
        document.getElementById('error-msg').classList.remove('hidden');
      }
    }

    const pages = {
      dashboard: { title: "Dashboard", icon: "📊", render: renderDashboard },
      crm: { title: "Client Vault", icon: "👥", render: renderCRM },
      playbook: { title: "Outperform Playbook", icon: "🚀", render: renderPlaybook },
      analytics: { title: "Analytics", icon: "📈", render: renderAnalytics },
      logger: { title: "Content Logger", icon: "📝", render: renderContentLogger },
      calculator: { title: "Cost Calculator", icon: "🧮", render: renderCalculator },
      competitors: { title: "Competitors", icon: "🏆", render: renderCompetitors }
    };

    function buildNav() {
      const nav = document.getElementById('nav');
      nav.innerHTML = '';
      Object.keys(pages).forEach(key => {
        const p = pages[key];
        const el = document.createElement('div');
        el.className = `flex items-center gap-3 px-4 py-3 rounded-2xl cursor-pointer hover:bg-zinc-800 ${key === 'dashboard' ? 'bg-zinc-800' : ''}`;
        el.innerHTML = `<span class="text-xl">${p.icon}</span><span>${p.title}</span>`;
        el.onclick = () => {
          document.querySelectorAll('#nav > div').forEach(d => d.classList.remove('bg-zinc-800'));
          el.classList.add('bg-zinc-800');
          document.getElementById('page-title').textContent = p.title;
          p.render();
        };
        nav.appendChild(el);
      });
    }

    // ==================== DASHBOARD ====================
    function renderDashboard() {
      document.getElementById('main-content').innerHTML = `
        <div class="max-w-6xl mx-auto">
          <h1 class="text-5xl font-bold text-amber-400 mb-8">Welcome back, Troy</h1>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
            <div onclick="pages.crm.render()" class="bg-zinc-900 rounded-3xl p-8 cursor-pointer hover:bg-zinc-800"><div class="text-5xl mb-4">👥</div><div class="text-xl font-semibold">Client Vault</div></div>
            <div onclick="pages.playbook.render()" class="bg-zinc-900 rounded-3xl p-8 cursor-pointer hover:bg-zinc-800"><div class="text-5xl mb-4">🚀</div><div class="text-xl font-semibold">Outperform Playbook</div></div>
            <div onclick="pages.analytics.render()" class="bg-zinc-900 rounded-3xl p-8 cursor-pointer hover:bg-zinc-800"><div class="text-5xl mb-4">📈</div><div class="text-xl font-semibold">Analytics</div></div>
            <div onclick="pages.logger.render()" class="bg-zinc-900 rounded-3xl p-8 cursor-pointer hover:bg-zinc-800"><div class="text-5xl mb-4">📝</div><div class="text-xl font-semibold">Content Logger</div></div>
          </div>
        </div>`;
    }

    // ==================== CLIENT VAULT (Full) ====================
    let clients = JSON.parse(localStorage.getItem('clients')) || [];
    function saveClients() { localStorage.setItem('clients', JSON.stringify(clients)); }

    function renderCRM() {
      let html = `<div class="max-w-6xl mx-auto"><div class="flex justify-between mb-6"><h2 class="text-3xl font-bold">Client Vault</h2><button onclick="addClient()" class="bg-amber-400 text-zinc-950 px-6 py-3 rounded-3xl">+ New Client</button></div><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="client-grid"></div></div>`;
      document.getElementById('main-content').innerHTML = html;
      renderClientGrid();
    }

    function addClient() {
      const name = prompt("Client Full Name");
      if (!name) return;
      clients.push({id: Date.now(), name, phone:"", email:"", purchases:[]});
      saveClients();
      renderClientGrid();
    }

    function renderClientGrid() {
      const grid = document.getElementById('client-grid');
      grid.innerHTML = clients.map(c => `
        <div class="bg-zinc-900 rounded-3xl p-6 cursor-pointer hover:bg-zinc-800" onclick="viewClient(${c.id})">
          <div class="font-semibold text-lg">${c.name}</div>
          <div class="text-sm text-zinc-400 mt-2">${c.email || 'No email'}</div>
        </div>`).join('');
    }

    function viewClient(id) {
      alert("Client details view - full version can be expanded further if needed");
    }

    // ==================== PLAYBOOK ====================
    function renderPlaybook() {
      document.getElementById('main-content').innerHTML = `
        <div class="max-w-5xl mx-auto space-y-12">
          <h2 class="text-3xl font-bold">Outperform Playbook</h2>
          <button onclick="generateWeeklyPlan()" class="bg-amber-400 text-zinc-950 px-8 py-4 rounded-3xl">Generate This Week's Content Plan</button>
          <div id="plan-output" class="mt-6"></div>
        </div>`;
    }

    function generateWeeklyPlan() {
      document.getElementById('plan-output').innerHTML = `
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-zinc-900 p-6 rounded-3xl">Monday: Workshop Reel</div>
          <div class="bg-zinc-900 p-6 rounded-3xl">Tuesday: Transformation Before/After</div>
          <div class="bg-zinc-900 p-6 rounded-3xl">Wednesday: Education Carousel</div>
          <div class="bg-zinc-900 p-6 rounded-3xl">Thursday: Client Story</div>
        </div>`;
    }

    // ==================== OTHER SECTIONS ====================
    function renderAnalytics() { document.getElementById('main-content').innerHTML = `<div class="text-center py-20 text-3xl">📈 Analytics Tracker (Ready)</div>`; }
    function renderContentLogger() { document.getElementById('main-content').innerHTML = `<div class="text-center py-20 text-3xl">📝 Content Logger (Ready)</div>`; }
    function renderCalculator() { document.getElementById('main-content').innerHTML = `<div class="text-center py-20 text-3xl">🧮 Cost Calculator (Ready)</div>`; }
    function renderCompetitors() { document.getElementById('main-content').innerHTML = `<div class="text-center py-20 text-3xl">🏆 Competitor Intelligence (Ready)</div>`; }

    document.getElementById('password-input').addEventListener('keypress', e => { if (e.key === 'Enter') checkPassword(); });
  </script>
</body>
</html>
