<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Troy Clancy Jewellery • JewelCraft</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
  </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

  <!-- PASSWORD SCREEN -->
  <div id="password-screen" class="fixed inset-0 bg-zinc-950 flex items-center justify-center z-50">
    <div class="bg-zinc-900 rounded-3xl p-12 w-full max-w-md text-center">
      <div class="text-5xl mb-6">💎</div>
      <h1 class="text-3xl font-bold mb-2">JewelCraft Insights</h1>
      <p class="text-amber-400 mb-8">Troy Clancy Jewellery • Private</p>
      <input id="password-input" type="password" placeholder="Enter Password" class="w-full bg-zinc-800 text-center rounded-2xl p-5 text-lg mb-6">
      <button onclick="checkPassword()" class="w-full bg-amber-400 text-zinc-950 font-semibold py-5 rounded-3xl text-lg">UNLOCK DASHBOARD</button>
      <p id="error-msg" class="text-red-400 mt-4 text-sm hidden">Incorrect password</p>
    </div>
  </div>

  <!-- MAIN APP -->
  <div id="main-app" class="hidden flex h-screen">
    <div class="w-72 bg-zinc-900 border-r border-zinc-800 flex flex-col">
      <div class="p-6 border-b border-zinc-800">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gradient-to-br from-amber-400 to-yellow-600 rounded-xl flex items-center justify-center text-xl">💎</div>
          <div><h1 class="text-2xl font-bold">JewelCraft</h1><p class="text-amber-400 text-sm">Troy Clancy</p></div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-1" id="nav"></nav>
    </div>

    <div class="flex-1 flex flex-col">
      <header class="h-16 bg-zinc-900 border-b border-zinc-800 px-8 flex items-center justify-between">
        <h2 id="page-title" class="text-2xl font-semibold">Dashboard</h2>
      </header>
      <div class="flex-1 overflow-auto p-8" id="main-content"></div>
    </div>
  </div>

  <script>
    const CORRECT_PASSWORD = "c99#1@axWTE!NH^B";

    function checkPassword() {
      if (document.getElementById('password-input').value === CORRECT_PASSWORD) {
        document.getElementById('password-screen').classList.add('hidden');
        document.getElementById('main-app').classList.remove('hidden');
        buildNav();
        pages.dashboard.render();
      } else {
        document.getElementById('error-msg').classList.remove('hidden');
      }
    }

    const pages = {
      dashboard: { title: "Dashboard", icon: "📊", render: renderDashboard },
      crm: { title: "Client Vault", icon: "👥", render: renderCRM },
      playbook: { title: "Outperform Playbook", icon: "🚀", render: renderPlaybook },
      marketing: { title: "Marketing Strategies", icon: "📣", render: renderMarketing },
      analytics: { title: "Analytics", icon: "📈", render: () => {} },
      logger: { title: "Content Logger", icon: "📝", render: () => {} },
      calculator: { title: "Cost Calculator", icon: "🧮", render: renderCalculator },
      competitors: { title: "Competitors", icon: "🏆", render: () => {} }
    };

    function buildNav() {
      const nav = document.getElementById('nav');
      nav.innerHTML = '';
      Object.keys(pages).forEach(key => {
        const p = pages[key];
        const el = document.createElement('div');
        el.className = `flex items-center gap-3 px-4 py-3 rounded-2xl cursor-pointer hover:bg-zinc-800 ${key === 'dashboard' ? 'bg-zinc-800' : ''}`;
        el.innerHTML = `<span class="text-xl">${p.icon}</span><span>${p.title}</span>`;
        el.onclick = () => {
          document.querySelectorAll('#nav > div').forEach(d => d.classList.remove('bg-zinc-800'));
          el.classList.add('bg-zinc-800');
          document.getElementById('page-title').textContent = p.title;
          p.render();
        };
        nav.appendChild(el);
      });
    }

    function renderDashboard() {
      document.getElementById('main-content').innerHTML = `<div class="max-w-6xl mx-auto text-center py-12"><h1 class="text-5xl font-bold text-amber-400">Welcome back, Troy</h1></div>`;
    }

    function renderMarketing() {
      document.getElementById('main-content').innerHTML = `
        <div class="max-w-5xl mx-auto space-y-12">
          <h2 class="text-3xl font-bold">2026 Jewelry Marketing Strategies</h2>
          
          <div class="bg-zinc-900 rounded-3xl p-8">
            <h3 class="font-semibold mb-4">Your Core Positioning</h3>
            <p>"Handcrafted on-site in Burleigh Heads by Master Jeweller Troy Clancy — 30+ years experience"</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-zinc-900 rounded-3xl p-8">
              <h3 class="font-semibold mb-4">Top Content Types</h3>
              <ul class="space-y-3">
                <li>🔨 Workshop Reels (Craftsman's Table)</li>
                <li>🔄 Transformation Tuesday (Before/After)</li>
                <li>📚 Education Carousels (4Cs, Metals, Care)</li>
                <li>💍 Client Stories & Proposals</li>
                <li>📌 Pinterest Styling Boards</li>
              </ul>
            </div>
            <div class="bg-zinc-900 rounded-3xl p-8">
              <h3 class="font-semibold mb-4">Quick Wins</h3>
              <ul class="space-y-3">
                <li>Launch TikTok immediately</li>
                <li>Daily posting (5x/week minimum)</li>
                <li>Google Reviews campaign</li>
                <li>Wedding vendor partnerships</li>
                <li>Email list building</li>
              </ul>
            </div>
          </div>

          <div class="bg-zinc-900 rounded-3xl p-8">
            <h3 class="font-semibold mb-4">Cost Calculator Reminder</h3>
            <p>Use 300% margin + 10% GST • Labour $350/hour</p>
          </div>
        </div>`;
    }

    function renderCalculator() {
      document.getElementById('main-content').innerHTML = `
        <div class="max-w-2xl mx-auto bg-zinc-900 rounded-3xl p-10">
          <h2 class="text-3xl font-bold mb-8">Cost Calculator (300% Margin + GST)</h2>
          <div class="space-y-6">
            <div><label class="block text-sm mb-2">Metal Weight (grams)</label><input id="weight" type="number" value="15" class="w-full bg-zinc-800 p-4 rounded-2xl"></div>
            <div><label class="block text-sm mb-2">Labour Hours</label><input id="hours" type="number" value="20" class="w-full bg-zinc-800 p-4 rounded-2xl"></div>
            <div><label class="block text-sm mb-2">Gem Cost ($)</label><input id="gems" type="number" value="2500" class="w-full bg-zinc-800 p-4 rounded-2xl"></div>
            <button onclick="calculatePrice()" class="w-full bg-amber-400 text-zinc-950 py-6 rounded-3xl text-xl font-bold">CALCULATE RETAIL PRICE</button>
            <div id="result" class="mt-8 text-xl"></div>
          </div>
        </div>`;
    }

    window.calculatePrice = function() {
      const weight = parseFloat(document.getElementById('weight').value) || 0;
      const hours = parseFloat(document.getElementById('hours').value) || 0;
      const gems = parseFloat(document.getElementById('gems').value) || 0;
      const labour = hours * 350;
      const totalCost = (weight * 120) + labour + gems + 300;
      const retail = Math.round(totalCost * 4);
      const gst = Math.round(retail * 1.1);
      document.getElementById('result').innerHTML = `
        <div class="bg-zinc-800 p-8 rounded-3xl">
          <div class="flex justify-between text-2xl"><span>Retail ex GST</span><span class="text-amber-400">$${retail}</span></div>
          <div class="flex justify-between text-xl mt-4"><span>Incl. 10% GST</span><span>$${gst}</span></div>
        </div>`;
    };

    // Enter key
    document.getElementById('password-input').addEventListener('keypress', e => { if (e.key === 'Enter') checkPassword(); });
  </script>
</body>
</html>
